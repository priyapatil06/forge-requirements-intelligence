# Application
FORGE_ENV=development
FORGE_SECRET_KEY=replace-with-a-long-random-value
FORGE_FRONTEND_URL=http://localhost:5173
FORGE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database: SQLite works for local development. Docker Compose overrides this with PostgreSQL.
FORGE_DATABASE_URL=sqlite:///./forge.db

# Claude API
FORGE_MOCK_LLM=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Jira OAuth 2.0 (3LO). Leave blank until you create an Atlassian developer app.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:8000/api/v1/jira/callback
ATLASSIAN_SCOPES=read:jira-work write:jira-work read:jira-user offline_access

# Used to encrypt Jira access and refresh tokens at rest.
# Generate a production key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FORGE_TOKEN_ENCRYPTION_KEY=
